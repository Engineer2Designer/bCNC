// GLSL ES 1.00
#version 100
precision highp float;  // Required in fragment shader

varying vec3 color_;
varying float position_;
varying vec2 dash_;

uniform float zoom;

void main() {
    float loc = mod(position_ * zoom, dash_.x + dash_.y);

    if (loc <= dash_.x)
    {
        gl_FragColor = vec4(color_, 1.0);
    }
    else{
        discard;
    }
}