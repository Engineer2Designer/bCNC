// GLSL ES 1.00
#version 100
precision highp float;  // Required in fragment shader

varying vec3 color;     // Color passed from vertex shader
varying float linePos;
varying float dashRatio_;

uniform float zoom;

void main() {
    float dashSize = 8.; // dash size in pixels

    if (mod(linePos * zoom, dashSize) <= dashRatio_ * dashSize) {
        gl_FragColor = vec4(color, 1.0);
    }
    else {
        gl_FragColor = vec4(0., 0., 0., 0.);
    }
}