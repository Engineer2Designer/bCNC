// GLSL ES 1.00
#version 100
attribute vec3 xyz;
attribute vec3 color;
attribute vec2 dash;
attribute float position;

varying vec3 color_;
varying float position_;
varying vec2 dash_;

uniform mat4 MVP;

void main() {
    gl_Position = MVP * vec4(xyz, 1);

    color_ = color;
    dash_ = dash;
    position_ = position;
}