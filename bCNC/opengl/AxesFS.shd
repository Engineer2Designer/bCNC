// GLSL ES 1.00
#version 100
precision highp float;  // Required in fragment shader

varying vec3 color;     // Color passed from vertex shader
varying float position_;

const float dash1 = 6.0; // draw: 6 pixels
const float dash2 = 2.0; // gap: 2 pixels

uniform float zoom;

void main() {

    float loc = mod(position_ * zoom, dash1 + dash2);

    if (loc <= dash1)
    {
        gl_FragColor = vec4(color, 1.0);
    }
    else
    {
        discard;
    }
}