// GLSL ES 1.00
#version 100
precision highp float;  // Required in fragment shader

varying float position_;

const float dash1 = 2.0; // draw: 2 pixels
const float dash2 = 6.0; // gap: 6 pixels

uniform float zoom;

void main() {

    float loc = mod(position_ * zoom, dash1 + dash2);

    if (loc <= dash1)
    {
        gl_FragColor = vec4(0.5, 0.5, 0.5, 1.0);
    }
    else
    {
        discard;
    }
}